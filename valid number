class Solution {
    public boolean isNumber(String s) {
        s = s.trim(); // Although LeetCode usually handles this, it's good practice
        
        boolean seenDigit = false;
        boolean seenDot = false;
        boolean seenE = false;
        
        for (int i = 0; i < s.length(); i++) {
            char c = s.charAt(i);
            
            if (Character.isDigit(c)) {
                seenDigit = true;
            } else if (c == '+' || c == '-') {
                // Sign must be at start or right after 'e'
                if (i > 0 && s.charAt(i - 1) != 'e' && s.charAt(i - 1) != 'E') {
                    return false;
                }
            } else if (c == 'e' || c == 'E') {
                // 'e' can only appear once and must follow a digit
                if (seenE || !seenDigit) {
                    return false;
                }
                seenE = true;
                seenDigit = false; // Reset to ensure a digit follows 'e'
            } else if (c == '.') {
                // Dot can only appear once and cannot be after 'e'
                if (seenDot || seenE) {
                    return false;
                }
                seenDot = true;
            } else {
                // Any other character is invalid
                return false;
            }
        }
        
        return seenDigit;
    }
}
